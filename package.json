{
  "private": true,
  "scripts": {
    "test": "node --test",
    "test:engine": "node --test test/engine.test.js",
    "test:engine:ts": "node --import tsx --test test/engine.test.ts",
    "test:game:ts": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "build:engine": "tsc -p tsconfig.json",
    "simulate:italia": "node --import tsx src/simulate-italia.ts",
    "build:web": "esbuild src/engine/browser-entry.ts --bundle --format=iife --global-name=HegemonEngine --platform=browser --outfile=web/engine.bundle.js",
    "play:web": "npm run build:web",
    "vercel-build": "npm run build:web"
  },
  "devDependencies": {
    "@types/node": "^24.0.14",
    "esbuild": "^0.25.8",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "jose": "^5.9.0",
    "@upstash/redis": "^1.34.0"
  }
}
